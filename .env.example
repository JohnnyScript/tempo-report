# Copia este archivo a .env y rellena los valores. NO se sube a ningún lado.

# URL base de tu Jira (sin barra final)
JIRA_BASE_URL=https://tu-empresa.atlassian.net

# Correo de TU cuenta en ESE Jira (normalmente el corporativo)
JIRA_EMAIL=tu.correo@empresa.com

# Token de API de Jira: https://id.atlassian.net/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Token de API de Tempo: Jira -> Apps -> Tempo -> Settings -> API integration -> New token
# (Solo se usa en la fase de envío, no en el paso de descubrimiento)
TEMPO_API_TOKEN=

# Opcional: fecha de inicio YYYY-MM-DD. Si se deja vacío, usa hoy menos 6 meses.
SINCE=
